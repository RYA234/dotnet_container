@{
    ViewData["Title"] = "フルテーブルスキャンデモ";
}

<div class="container mt-4">
    <h1 class="mb-4">🔍 フルテーブルスキャンデモ</h1>
    <p class="lead">インデックスの有無によるパフォーマンス差を体感できるデモ</p>

    <div class="card mb-4">
        <div class="card-header bg-warning text-dark">
            <h2 class="h4 mb-0">Step 1: セットアップ（100万件データ生成）</h2>
        </div>
        <div class="card-body">
            <p>LargeUsersテーブルに100万件のダミーデータを生成します。既にデータが存在する場合はスキップされます。</p>
            <button class="btn btn-warning" onclick="runSetup()">セットアップ実行</button>
            <div id="result-setup" class="mt-3" style="display: none;">
                <pre id="result-setup-content" class="bg-light p-3 rounded"></pre>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-danger text-white">
            <h2 class="h4 mb-0">Step 2: インデックスなし検索（フルスキャン）</h2>
        </div>
        <div class="card-body">
            <p>Emailカラムにインデックスがない状態で検索します。100万件を全件スキャンするため低速です。</p>
            <div class="mb-3">
                <label for="emailInput" class="form-label">検索するEmail</label>
                <input type="text" id="emailInput" class="form-control" value="user0500000@example.com" style="max-width: 400px;">
            </div>
            <button class="btn btn-danger" onclick="runWithoutIndex()">インデックスなし検索</button>
            <div id="result-without-index" class="mt-3" style="display: none;">
                <pre id="result-without-index-content" class="bg-light p-3 rounded"></pre>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-info text-white">
            <h2 class="h4 mb-0">Step 3: インデックス作成</h2>
        </div>
        <div class="card-body">
            <p>EmailカラムにインデックスIX_LargeUsers_Emailを作成します。</p>
            <button class="btn btn-info" onclick="runCreateIndex()">インデックス作成</button>
            <div id="result-create-index" class="mt-3" style="display: none;">
                <pre id="result-create-index-content" class="bg-light p-3 rounded"></pre>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h2 class="h4 mb-0">Step 4: インデックスあり検索</h2>
        </div>
        <div class="card-body">
            <p>インデックスを使って検索します。インデックスなしと比べて劇的に高速です。</p>
            <button class="btn btn-success" onclick="runWithIndex()">インデックスあり検索</button>
            <div id="result-with-index" class="mt-3" style="display: none;">
                <pre id="result-with-index-content" class="bg-light p-3 rounded"></pre>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h2 class="h4 mb-0">性能比較</h2>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>メトリクス</th>
                            <th>インデックスなし</th>
                            <th>インデックスあり</th>
                            <th>改善率</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>実行時間（目安）</td>
                            <td>数十〜数百ms</td>
                            <td>1ms以下</td>
                            <td><strong class="text-success">99%以上削減</strong> ⚡</td>
                        </tr>
                        <tr>
                            <td>スキャン方式</td>
                            <td>フルテーブルスキャン（全100万件）</td>
                            <td>インデックス検索（B-Tree）</td>
                            <td>-</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a href="~/Demo/Index" class="btn btn-secondary">← デモ一覧に戻る</a>
    </div>
</div>

<script>
async function runSetup() {
    const btn = event.target;
    btn.disabled = true;
    btn.textContent = '実行中...';
    try {
        const response = await fetch('/dotnet/api/demo/full-scan/setup', { method: 'POST' });
        const data = await response.json();
        document.getElementById('result-setup-content').textContent = JSON.stringify(data, null, 2);
        document.getElementById('result-setup').style.display = 'block';
    } catch (error) {
        document.getElementById('result-setup-content').textContent = 'Error: ' + error.message;
        document.getElementById('result-setup').style.display = 'block';
    } finally {
        btn.disabled = false;
        btn.textContent = 'セットアップ実行';
    }
}

async function runWithoutIndex() {
    const email = document.getElementById('emailInput').value;
    try {
        const response = await fetch(`/dotnet/api/demo/full-scan/without-index?email=${encodeURIComponent(email)}`);
        const data = await response.json();
        document.getElementById('result-without-index-content').textContent = JSON.stringify(data, null, 2);
        document.getElementById('result-without-index').style.display = 'block';
    } catch (error) {
        document.getElementById('result-without-index-content').textContent = 'Error: ' + error.message;
        document.getElementById('result-without-index').style.display = 'block';
    }
}

async function runCreateIndex() {
    const btn = event.target;
    btn.disabled = true;
    btn.textContent = '作成中...';
    try {
        const response = await fetch('/dotnet/api/demo/full-scan/create-index', { method: 'POST' });
        const data = await response.json();
        document.getElementById('result-create-index-content').textContent = JSON.stringify(data, null, 2);
        document.getElementById('result-create-index').style.display = 'block';
    } catch (error) {
        document.getElementById('result-create-index-content').textContent = 'Error: ' + error.message;
        document.getElementById('result-create-index').style.display = 'block';
    } finally {
        btn.disabled = false;
        btn.textContent = 'インデックス作成';
    }
}

async function runWithIndex() {
    const email = document.getElementById('emailInput').value;
    try {
        const response = await fetch(`/dotnet/api/demo/full-scan/with-index?email=${encodeURIComponent(email)}`);
        const data = await response.json();
        document.getElementById('result-with-index-content').textContent = JSON.stringify(data, null, 2);
        document.getElementById('result-with-index').style.display = 'block';
    } catch (error) {
        document.getElementById('result-with-index-content').textContent = 'Error: ' + error.message;
        document.getElementById('result-with-index').style.display = 'block';
    }
}
</script>
