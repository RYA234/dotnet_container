@{
    ViewData["Title"] = "ホーム";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>.NET Container</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      background: white;
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
      max-width: 1000px;
      margin: 0 auto;
      padding: 40px;
    }

    h1 { color: #667eea; font-size: 2.5rem; margin-bottom: 8px; }
    .subtitle { color: #666; margin-bottom: 30px; font-size: 1.1rem; }

    .tech-stack { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 30px; }
    .tech-tag {
      background: #667eea; color: white;
      padding: 6px 12px; border-radius: 6px; font-size: 0.85rem; font-weight: 500;
    }

    .section-title {
      font-size: 1.3rem; font-weight: 700; margin: 30px 0 12px;
      border-bottom: 2px solid #667eea; padding-bottom: 6px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 24px;
    }

    .feature-item a {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      background: #f7f7f7;
      border-radius: 8px;
      text-decoration: none;
      color: #333;
      transition: all 0.2s ease;
      border-left: 4px solid #667eea;
      font-size: 0.9rem;
    }

    .feature-item a:hover { background: #667eea; color: white; transform: translateX(4px); }
    .feature-item a.todo { border-left-color: #ccc; color: #333; }
    .feature-item a.todo:hover { background: #f0f0f0; color: #999; transform: none; }

    .badge {
      font-size: 0.7rem; padding: 2px 7px; border-radius: 10px;
      font-weight: 600; white-space: nowrap; margin-left: auto;
    }
    .badge.level-初級 { background: #d4edda; color: #155724; }
    .badge.level-中級 { background: #fff3cd; color: #856404; }
    .badge.level-上級 { background: #f8d7da; color: #721c24; }

    .legend { font-size: 0.8rem; color: #999; margin-top: 8px; }

    footer {
      margin-top: 30px; padding-top: 20px;
      border-top: 1px solid #ddd; text-align: center; color: #666; font-size: 0.9rem;
    }
    footer a { color: #667eea; text-decoration: none; margin: 0 10px; }
    footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="container">
    <h1>.NET Container</h1>
    <p class="subtitle">Feature-based ASP.NET Core MVC Application on AWS ECS</p>

    <div class="tech-stack">
      <span class="tech-tag">C#</span>
      <span class="tech-tag">ASP.NET Core</span>
      <span class="tech-tag">AWS ECS Fargate</span>
      <span class="tech-tag">xUnit</span>
      <span class="tech-tag">Supabase</span>
      <span class="tech-tag">Docker</span>
    </div>

    <div class="section-title">📊 デモ編（SQLパフォーマンス）</div>
    <div class="grid">
      <div class="feature-item"><a href="~/Demo/Performance"><span>✅</span> N+1問題 <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/FullScan"><span>✅</span> フルテーブルスキャン <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/SelectStar"><span>✅</span> SELECT * の無駄遣い <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/LikeSearch"><span>✅</span> LIKE中間一致検索 <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/DataStructures" class="todo"><span>❌</span> データ構造とアルゴリズム <span class="badge level-中級">中級</span></a></div>
    </div>

    <div class="section-title">🔧 共通設計デモ</div>
    <div class="grid">
      <div class="feature-item"><a href="~/Demo/ErrorHandling"><span>✅</span> エラーハンドリング <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/Logging"><span>✅</span> ログ <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/Validation"><span>✅</span> バリデーション <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/Security" class="todo"><span>❌</span> セキュリティ <span class="badge level-中級">中級</span></a></div>
      <div class="feature-item"><a href="~/Demo/DatabaseConnection" class="todo"><span>❌</span> DB接続 <span class="badge level-中級">中級</span></a></div>
    </div>

    <div class="section-title">🏢 基幹システム編</div>
    <div class="grid">
      <div class="feature-item"><a href="~/Inventory/Index" class="todo"><span>❌</span> 在庫管理 <span class="badge level-中級">中級</span></a></div>
      <div class="feature-item"><a href="~/Sales/Index" class="todo"><span>❌</span> 販売管理 <span class="badge level-中級">中級</span></a></div>
      <div class="feature-item"><a href="~/Production/Index" class="todo"><span>❌</span> 生産管理 <span class="badge level-中級">中級</span></a></div>
    </div>

    <div class="section-title">🎨 デザインパターン編</div>
    <div class="grid">
      <div class="feature-item"><a href="~/Demo/DesignPattern/Singleton" class="todo"><span>❌</span> Singleton <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/DesignPattern/FactoryMethod" class="todo"><span>❌</span> Factory Method <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/DesignPattern/Repository" class="todo"><span>❌</span> Repository <span class="badge level-中級">中級</span></a></div>
      <div class="feature-item"><a href="~/Demo/DesignPattern/Strategy" class="todo"><span>❌</span> Strategy <span class="badge level-中級">中級</span></a></div>
      <div class="feature-item"><a href="~/Demo/DesignPattern/Observer" class="todo"><span>❌</span> Observer <span class="badge level-中級">中級</span></a></div>
      <div class="feature-item"><a href="~/Demo/DesignPattern/Decorator" class="todo"><span>❌</span> Decorator <span class="badge level-中級">中級</span></a></div>
      <div class="feature-item"><a href="~/Demo/DesignPattern/Command" class="todo"><span>❌</span> Command <span class="badge level-中級">中級</span></a></div>
    </div>

    <div class="section-title">🧪 テスト技法編</div>
    <div class="grid">
      <div class="feature-item"><a href="~/Demo/TestingTechniques/EquivalencePartitioning" class="todo"><span>❌</span> 同値分割 <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/TestingTechniques/BoundaryValue" class="todo"><span>❌</span> 境界値分析 <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/TestingTechniques/DecisionTable" class="todo"><span>❌</span> デシジョンテーブル <span class="badge level-中級">中級</span></a></div>
      <div class="feature-item"><a href="~/Demo/TestingTechniques/StateTransition" class="todo"><span>❌</span> 状態遷移テスト <span class="badge level-中級">中級</span></a></div>
    </div>

    <div class="section-title">🏗️ ドメイン駆動設計編</div>
    <div class="grid">
      <div class="feature-item"><a href="~/Demo/DDD/Entity" class="todo"><span>❌</span> エンティティ <span class="badge level-中級">中級</span></a></div>
      <div class="feature-item"><a href="~/Demo/DDD/ValueObject" class="todo"><span>❌</span> 値オブジェクト <span class="badge level-中級">中級</span></a></div>
      <div class="feature-item"><a href="~/Demo/DDD/Aggregate" class="todo"><span>❌</span> 集約・リポジトリ <span class="badge level-上級">上級</span></a></div>
    </div>

    <div class="section-title">🗄️ テーブル設計編</div>
    <div class="grid">
      <div class="feature-item"><a href="~/Demo/TableDesign/Normalization" class="todo"><span>❌</span> 正規化 <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/TableDesign/ERDiagram" class="todo"><span>❌</span> ER図の読み方 <span class="badge level-初級">初級</span></a></div>
      <div class="feature-item"><a href="~/Demo/TableDesign/Index" class="todo"><span>❌</span> インデックス設計 <span class="badge level-中級">中級</span></a></div>
    </div>

    <p class="legend">凡例: ✅ 実装済み　❌ 未実装</p>

    <footer>
      <p>Architecture: Feature-based | Pattern: MVC</p>
      <a href="https://github.com/RYA234/dotnet_container" target="_blank">GitHub</a>
      <a href="/dotnet/healthz">Health Check</a>
    </footer>
  </div>
</body>
</html>
