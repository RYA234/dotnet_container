@{
    var statusCode = (int)ViewData["StatusCode"];
    var is404 = statusCode == 404;
    ViewData["Title"] = is404 ? "準備中" : $"エラー {statusCode}";
}

<div class="container py-5 text-center">
    @if (is404)
    {
        <div style="font-size: 4rem;">🚧</div>
        <h1 class="mt-3">このページは準備中です</h1>
        <p class="text-muted mt-2">現在実装中のコンテンツです。もうしばらくお待ちください。</p>
    }
    else
    {
        <div style="font-size: 4rem;">⚠️</div>
        <h1 class="mt-3">エラーが発生しました</h1>
        <p class="text-muted mt-2">ステータスコード: <strong>@statusCode</strong></p>
    }

    <a href="~/" class="btn btn-primary mt-4">← トップへ戻る</a>
</div>
