<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ASP.NET Core MVC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="~/Home/Index">🏠 ASP.NET MVC</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="~/Home/Index">ホーム</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownEducation" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            🎓 エンジニア教育用
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdownEducation">
                            <li><a class="dropdown-item" href="~/Demo/Index">デモ一覧</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li class="dropdown-submenu">
                                <a class="dropdown-item" href="#">⚡ SQLパフォーマンス</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="~/Demo/Performance">✅ N+1問題</a></li>
                                    <li><a class="dropdown-item disabled" href="#">🚧 インデックス（未実装）</a></li>
                                </ul>
                            </li>
                            <li><a class="dropdown-item" href="~/Demo/DataStructures">🚧 データ構造とアルゴリズム</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li class="dropdown-submenu">
                                <a class="dropdown-item" href="#">📋 共通設計</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="~/Demo/ErrorHandling">✅ エラーハンドリング</a></li>
                                    <li><a class="dropdown-item" href="~/Demo/Security">🚧 セキュリティ</a></li>
                                    <li><a class="dropdown-item" href="~/Demo/Logging">✅ ログ</a></li>
                                    <li><a class="dropdown-item" href="~/Demo/Validation">✅ バリデーション</a></li>
                                    <li><a class="dropdown-item" href="~/Demo/DatabaseConnection">🚧 DB接続</a></li>
                                </ul>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownCore" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            🏢 基幹システム
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdownCore">
                            <li><a class="dropdown-item" href="~/Inventory/Index">📦 在庫管理</a></li>
                            <li><a class="dropdown-item" href="~/Sales/Index">💰 販売管理</a></li>
                            <li><a class="dropdown-item" href="~/Production/Index">🏭 生産管理</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownPattern" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            🎨 デザインパターン
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdownPattern">
                            <li><a class="dropdown-item disabled" href="#">🚧 Singleton</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 Factory Method</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 Repository</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 Strategy</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 Observer</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 Decorator</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 Command</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownTesting" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            🧪 テスト技法
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdownTesting">
                            <li><a class="dropdown-item disabled" href="#">🚧 同値分割</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 境界値分析</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 デシジョンテーブル</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 状態遷移テスト</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownDDD" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            🏗️ DDD
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdownDDD">
                            <li><a class="dropdown-item disabled" href="#">🚧 エンティティ</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 値オブジェクト</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 集約・リポジトリ</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownTable" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            🗄️ テーブル設計
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdownTable">
                            <li><a class="dropdown-item disabled" href="#">🚧 正規化</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 ER図の読み方</a></li>
                            <li><a class="dropdown-item disabled" href="#">🚧 インデックス設計</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container-fluid" style="padding: 20px;">
        @RenderBody()
    </main>

    <footer class="mt-5 py-3 bg-light text-center">
        <div class="container">
            <p class="mb-0">&copy; 2024 - ASP.NET Core MVC Application</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
